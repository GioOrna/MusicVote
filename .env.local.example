# YouTube Data API v3 key (get from https://console.cloud.google.com)
YOUTUBE_API_KEY=your_youtube_api_key_here

# Vercel KV (auto-filled when you connect a KV store in Vercel dashboard)
KV_REST_API_URL=your_kv_rest_api_url
KV_REST_API_TOKEN=your_kv_rest_api_token

# Secret token to authorize the "mark as played" admin action (choose any random string)
ADMIN_SECRET=your_admin_secret_here
